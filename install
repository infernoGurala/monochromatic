#!/usr/bin/env bash

# AI YouTube Shorts Generator Setup Script

# Exit immediately if a command exits with a non-zero status
set -e

# Color codes for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}===============================================${NC}"
echo -e "${GREEN}      AI YouTube Shorts Generator Setup        ${NC}"
echo -e "${BLUE}===============================================${NC}"

# 1. Check Python installation
echo -e "\n${YELLOW}[1/4] Checking prerequisites...${NC}"
if ! command -v python3 &> /dev/null; then
    echo -e "${RED}Error: python3 is not installed. Please install Python 3.10+ and try again.${NC}"
    exit 1
fi

PYTHON_VERSION=$(python3 -c 'import sys; print(".".join(map(str, sys.version_info[:2])))')
echo -e "Found Python version: ${GREEN}$PYTHON_VERSION${NC}"

# Check for venv module support (some Linux distros package it separately)
if ! python3 -c "import venv" &> /dev/null; then
    echo -e "${RED}Error: Python 'venv' module is missing.${NC}"
    echo -e "On Debian/Ubuntu, please run: ${YELLOW}sudo apt install python3-venv${NC}"
    exit 1
fi

# Check for FFmpeg (warn if missing, since it's needed for local mode)
if ! command -v ffmpeg &> /dev/null; then
    echo -e "${YELLOW}Warning: ffmpeg was not found on your PATH.${NC}"
    echo -e "It is required for local offline rendering mode."
    echo -e "On Debian/Ubuntu: ${GREEN}sudo apt install ffmpeg${NC}"
    echo -e "On macOS: ${GREEN}brew install ffmpeg${NC}"
fi

# 2. Create Virtual Environment
echo -e "\n${YELLOW}[2/4] Creating virtual environment (venv)...${NC}"
if [ -d "venv" ]; then
    echo -e "Virtual environment 'venv' already exists. Skipping creation."
else
    python3 -m venv venv
    echo -e "${GREEN}Virtual environment created successfully.${NC}"
fi

# 3. Upgrade pip and install dependencies
echo -e "\n${YELLOW}[3/4] Installing dependencies...${NC}"

# Determine which requirements file to install
INSTALL_LOCAL="n"
if [ -t 0 ]; then
    read -p "Do you want to install local offline mode dependencies (e.g. OpenCV, faster-whisper)? [y/N]: " INSTALL_LOCAL
fi

# Activate venv for installation context
source venv/bin/activate

# Upgrade pip inside the virtual environment
pip install --upgrade pip

if [[ "$INSTALL_LOCAL" =~ ^[Yy]$ ]]; then
    echo -e "Installing local/offline dependencies..."
    pip install -r requirements-local.txt
else
    echo -e "Installing standard API-mode dependencies..."
    pip install -r requirements.txt
fi

# 4. Create .env file template if it doesn't exist
echo -e "\n${YELLOW}[4/4] Setting up configuration (.env)...${NC}"
if [ -f ".env" ]; then
    echo -e ".env file already exists. Skipping creation."
else
    cat <<EOT > .env
# API mode (default)
MUAPI_API_KEY=your_muapi_key_here

# Local mode (--mode local)
LLM_PROVIDER=openai               # openai or gemini
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini          # optional, default gpt-4o-mini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash      # optional, default gemini-2.5-flash
LOCAL_WHISPER_MODEL=base          # tiny / base / small / medium / large-v3
LOCAL_WHISPER_DEVICE=auto         # auto / cpu / cuda
LOCAL_OUTPUT_DIR=output           # where local mp4s land
EOT
    echo -e "${GREEN}.env file template created. Please open it and fill in your keys.${NC}"
fi

echo -e "\n${GREEN}===============================================${NC}"
echo -e "${GREEN}            Setup Complete!                    ${NC}"
echo -e "${GREEN}===============================================${NC}"

# Detect shell to give the exact activation instruction
CURRENT_SHELL=$(basename "$SHELL")
echo -e "\nTo activate your virtual environment, run:"

if [ "$CURRENT_SHELL" = "fish" ]; then
    echo -e "  ${YELLOW}source venv/bin/activate.fish${NC}"
elif [ "$CURRENT_SHELL" = "csh" ] || [ "$CURRENT_SHELL" = "tcsh" ]; then
    echo -e "  ${YELLOW}source venv/bin/activate.csh${NC}"
else
    echo -e "  ${YELLOW}source venv/bin/activate${NC}"
fi

echo -e "\nTo run the application:"
echo -e "  - Web UI: ${GREEN}python app.py${NC}"
echo -e "  - CLI:    ${GREEN}python main.py \"<YOUTUBE_URL>\"${NC}"
